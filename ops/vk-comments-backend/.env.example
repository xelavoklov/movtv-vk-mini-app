# Database
POSTGRES_USER=vkapp
POSTGRES_PASSWORD=changeme
POSTGRES_DB=vkapp
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Assembled automatically by the app from the vars above; override if needed:
# DATABASE_URL=postgresql+asyncpg://vkapp:changeme@db:5432/vkapp

# VK Mini App
# Secret key from https://vk.com/editapp?id=<APP_ID>&section=options
VK_APP_SECRET=your_vk_app_client_secret

# JWT
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_this_to_a_long_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_SECONDS=604800

# App
APP_ENV=production
DEBUG=false
CORS_ORIGINS=https://vk.com,https://m.vk.com
